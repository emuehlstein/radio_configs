        "$ref": "#/$defs/ChannelPlan"
      },
      "title": "Channel Plans",
      "type": "array"
    },
    "authorizations": {
      "items": {
        "$ref": "#/$defs/Authorization"
      },
      "title": "Authorizations",
      "type": "array"
    },
    "contacts": {
