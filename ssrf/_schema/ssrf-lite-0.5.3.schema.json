  "title": "SSRF-Lite Reference Document",
  "description": "Schema for SSRF-Lite YAML reference documents (specification v0.5.3). Generated from the Pydantic models in ssrf/models/pydantic_models.py. See ssrf/_schema/SSRF-Lite-Spec.md for prose documentation.",
  "type": "object",
  "additionalProperties": false,
