        "channel_plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Channel Plan Id"
        },
        "channel_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
