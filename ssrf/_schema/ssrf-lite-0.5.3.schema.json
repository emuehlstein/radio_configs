              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeslots"
        },
        "nac": {
          "anyOf": [
            {
              "maximum": 4095,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nac"
        },
        "nxdn_ran": {
          "anyOf": [
            {
              "maximum": 63,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nxdn Ran"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
