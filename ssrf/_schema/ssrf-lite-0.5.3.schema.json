    "organizations": {
      "items": {
        "$ref": "#/$defs/Organization"
      },
      "title": "Organizations",
      "type": "array"
    },
    "locations": {
      "items": {
        "$ref": "#/$defs/Location"
      },
      "title": "Locations",
      "type": "array"
    },
    "stations": {
      "items": {
        "$ref": "#/$defs/Station"
      },
      "title": "Stations",
      "type": "array"
    },
    "antennas": {
