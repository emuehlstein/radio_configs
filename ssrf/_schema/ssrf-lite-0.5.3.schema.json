          "default": null,
          "title": "Notes"
        }
      },
      "required": [
        "id",
        "authority",
        "service"
      ],
      "title": "Authorization",
      "type": "object"
    },
    "ChannelPlan": {
      "additionalProperties": false,
      "description": "Collection of reusable channels (e.g., NOAA, marine).",
