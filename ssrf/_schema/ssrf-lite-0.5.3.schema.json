      "additionalProperties": false,
      "description": "Antenna definition with optional gain and height references.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "station_id": {
          "title": "Station Id",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "gain_dbi": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gain Dbi"
        },
        "height_agl_m": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Height Agl M"
        },
        "height_amsl_m": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
