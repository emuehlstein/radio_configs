        "$ref": "#/$defs/Antenna"
      },
      "title": "Antennas",
      "type": "array"
    },
    "rf_chains": {
      "items": {
        "$ref": "#/$defs/RFChain"
      },
      "title": "Rf Chains",
      "type": "array"
    },
    "channel_plans": {
